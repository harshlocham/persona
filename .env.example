# Copy to .env.local and fill in values.
# Pipeline scripts (pnpm persona) load .env and .env.local automatically.

# Google Gemini API key (required for chat)
GOOGLE_GENERATIVE_AI_API_KEY=

# YouTube Data API key (required for persona YouTube collection)
YOUTUBE_API_KEY=

# Optional: override default Gemini model
# GEMINI_MODEL=gemini-2.5-flash
