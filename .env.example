# Copy to .env.local and fill in values.
# Pipeline scripts (pnpm persona) load .env and .env.local automatically.

# Google Gemini API key (required for chat)
GOOGLE_GENERATIVE_AI_API_KEY=

# YouTube Data API key (required for persona YouTube collection)
YOUTUBE_API_KEY=

# Optional: override default Gemini model
# GEMINI_MODEL=gemini-2.5-flash

# Optional: custom brand logo shown in the header and used as the favicon.
# Set to a hosted image URL; leave empty to use the built-in icon.
# NEXT_PUBLIC_BRAND_LOGO_URL=

# Embedding stage (pnpm persona embed) — indexes chunks into Qdrant
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=
# QDRANT_COLLECTION=persona_knowledge
# EMBEDDING_MODEL=text-embedding-004
# EMBEDDING_DIMENSIONS=768
